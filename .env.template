# =========================================================================
# CMMS 환경변수 템플릿 (.env.template) — Git 커밋됨 (값 없음, 키 가이드용)
# =========================================================================
# 이 파일을 복사해 '.env'를 만들고 실제 값을 채워 사용하세요.
#   cp .env.template .env
# 로컬 실행: set -a; source .env; set +a; (cd backend && ./gradlew bootRun)
# 운영 실행: 아래 키들을 systemd EnvironmentFile / docker --env-file / k8s Secret으로 주입.
#
# 모든 자격증명은 환경변수로만 주입됩니다(application.yml에 기본값 없음).
# DB_*, JWT_SECRET 미설정 시 애플리케이션이 기동되지 않습니다(fail-fast).

# -------------------------------------------------------------------------
# 컨테이너 이미지 (운영 docker-compose.prod.yml = 레지스트리 pull)
# -------------------------------------------------------------------------
# CI가 빌드/푸시한 이미지를 서버가 pull. IMAGE_REGISTRY 미설정 시 compose가 즉시 실패(fail-fast).
IMAGE_REGISTRY=ghcr.io/your-org
# IMAGE_TAG=latest          # 배포 태그(미설정 시 latest). 운영은 불변 태그(커밋SHA 등) 권장

# -------------------------------------------------------------------------
# Database (Supabase PostgreSQL — Session Pooler)
# -------------------------------------------------------------------------
DB_URL=jdbc:postgresql://[YOUR-POOLER-HOST]:5432/postgres?ssl=true&sslmode=require
# 풀러 username 형식: postgres.<project-ref>
DB_USERNAME=postgres.[YOUR-PROJECT-REF]
DB_PASSWORD=
# 커넥션 풀 (선택, 기본 max 5 / idle 2)
# DB_POOL_MAX=5
# DB_POOL_MIN=2

# -------------------------------------------------------------------------
# JWT (필수)
# -------------------------------------------------------------------------
# 생성: openssl rand -base64 32  (운영/개발 환경마다 서로 다른 키 사용)
JWT_SECRET=
# JWT_EXPIRATION=1800000

# -------------------------------------------------------------------------
# 비밀번호 정책 (선택, 미설정 시 기본값 사용)
# -------------------------------------------------------------------------
# PWD_EXPIRY_DAYS=90      # 비밀번호 만료 일수(경과 시 변경 강제)
# PWD_MAX_FAILED=5        # 계정 잠금까지 허용하는 연속 실패 횟수
# PWD_LOCK_MINUTES=30     # 잠금 지속 시간(분)

# -------------------------------------------------------------------------
# [미구현] Object Storage (Supabase S3 호환)
# -------------------------------------------------------------------------
# 현재 애플리케이션 코드 미연동. 업로드 기능 구현 후 사용됨.
STORAGE_ENDPOINT=https://[YOUR-PROJECT-REF].supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=cmms-attachments
# STORAGE_REGION=ap-southeast-1
